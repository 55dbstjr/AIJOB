{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_TEAMMATE_MODE": "tmux"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$AIJOB_ROOT/.claude/hooks/load-env.sh\""
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(curl *)",
      "Bash(jq *)",
      "Bash(yq *)",
      "Bash(kubectl *)",
      "Bash(helm *)",
      "Bash(gh *)",
      "Bash(glab *)",
      "Bash(aws *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(which *)",
      "Bash(echo *)",
      "Bash(pwd)",
      "Bash(date *)"
    ],
    "deny": [
      "Bash(rm -rf *)"
    ]
  }
}
